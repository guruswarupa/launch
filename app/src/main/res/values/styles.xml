<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CustomDialogTheme" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:windowBackground">@drawable/alert_dialog_background</item>
        <item name="colorSurface">@android:color/transparent</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorPrimary">@color/nord7</item>
        <item name="colorAccent">@color/nord7</item>
        <item name="colorControlActivated">@color/nord7</item>
        <item name="colorControlHighlight">@color/dialog_button_background</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.Dialog</item>
        <item name="materialAlertDialogTitleTextStyle">@style/CustomDialogTitleStyle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/CustomDialogBodyStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/CustomDialogPositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/CustomDialogNegativeButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/CustomDialogNeutralButton</item>
        <item name="android:editTextStyle">@style/DialogEditText</item>
        <item name="editTextStyle">@style/DialogEditText</item>
        
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColor">@color/white</item>
        <!-- Force list items to be white -->
        <item name="android:textColorAlertDialogListItem">@color/white</item>
        <item name="textColorAlertDialogListItem">@color/white</item>
        
        <!-- Additional text color overrides for various dialog components -->
        <item name="android:textColorPrimaryDisableOnly">@color/white</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="ShapeAppearance.App.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>
    
    <style name="CustomDialogTitleStyle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="CustomDialogBodyStyle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
    
    <style name="CustomDialogPositiveButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/nord7</item>
        <item name="rippleColor">@color/dialog_button_background</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
    
    <style name="CustomDialogNegativeButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="rippleColor">@color/dialog_button_background</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="CustomDialogNeutralButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="rippleColor">@color/dialog_button_background</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="DialogEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:textCursorDrawable">@null</item>
        <item name="android:background">@drawable/dialog_input_background</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="DialogFieldLabel" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textColor">@color/nord7</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="DialogHelperText" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DialogTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="boxBackgroundColor">@android:color/transparent</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/nord7</item>
        <item name="hintTextColor">@color/nord7</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="helperTextTextColor">@color/text_secondary</item>
        <item name="counterTextColor">@color/text_secondary</item>
        <item name="errorTextColor">@color/red</item>
    </style>
    
    <style name="TextAppearance.Dialog.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PopupMenuStyle" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@drawable/menu_background</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:itemTextAppearance">@style/PopupMenuItemTextAppearance</item>
        <item name="colorControlNormal">@color/white</item>
        <item name="colorControlActivated">@color/white</item>
        <item name="colorControlHighlight">@color/white</item>
    </style>
    
    <style name="PopupMenuItemTextAppearance" parent="TextAppearance.AppCompat.Menu">
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>


    <style name="TextAppearance.Dialog.Item" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="NoteEditor.HeaderTitle" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NoteEditor.Subtitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="NoteEditor.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="NoteEditor.HelperText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="WidgetTextStyle">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">@drawable/widget_background</item>
        <item name="android:padding">8dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TimeWidgetStyle" parent="WidgetTextStyle">
        <item name="android:textSize">24sp</item>
    </style>

    <style name="DateWidgetStyle" parent="WidgetTextStyle">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="WeatherWidgetStyle" parent="WidgetTextStyle">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DialogButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/nord7</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="rippleColor">@color/nord7</item>
    </style>
    <style name="DayBadge">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:background">@drawable/day_badge_background</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/widget_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Icon shape styles for different corner radii -->
    <style name="IconShapeRound" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="IconShapeSquircle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">22%</item>
    </style>

    <style name="IconShapeSquared" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4%</item>
    </style>

    <style name="IconShapeTeardrop" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">38%</item>
    </style>

    <style name="IconShapeVortex" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">42%</item>
    </style>

    <style name="IconShapeOverlay" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12%</item>
    </style>

    <style name="TranslucentSpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/rounded_background</item>
        <item name="android:popupBackground">@drawable/menu_background</item>
        <item name="android:dropDownWidth">wrap_content</item>
        <item name="android:padding">8dp</item>
    </style>
</resources>
