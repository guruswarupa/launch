    <string name="desc_camera">Allows the app to take pictures and record videos. This can be used for scanning QR codes, taking profile pictures, or making video calls.</string>
    <string name="desc_microphone">Allows the app to record audio using the microphone. This is used for voice messages, voice search, or recording video with sound. Be careful if an app accesses this without reason.</string>
    <string name="desc_contacts">Allows the app to read your contact list. This helps in finding friends, suggesting contacts to message, or showing contact names.</string>
    <string name="desc_location">Allows the app to access your precise location (GPS). Highly sensitive data that reveals exactly where you are.</string>
    <string name="desc_location_approx">Allows the app to access your approximate location. Less sensitive than precise location but still reveals your general area.</string>
    <string name="desc_storage">Allows the app to read files from your storage. Apps can access your personal documents and files with this.</string>
    <string name="desc_storage_write">Allows the app to save or modify files in your storage.</string>
    <string name="desc_sms">Allows the app to read your text messages. This is highly sensitive as it can include OTPs and private conversations.</string>
    <string name="desc_phone">Allows the app to make phone calls. This could lead to unexpected charges if abused.</string>
    <string name="desc_notifications">Allows the app to show you notifications. Can be used for spam if not managed.</string>
    <string name="desc_photos">Allows the app to specifically access your photos.</string>
    <string name="desc_videos">Allows the app to specifically access your videos.</string>
    <string name="desc_audio">Allows the app to specifically access your audio files.</string>

    
