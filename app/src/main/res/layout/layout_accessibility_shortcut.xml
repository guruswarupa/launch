<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A6000000">

    <LinearLayout
        android:id="@+id/menu_container"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:background="@drawable/rounded_background"
        android:backgroundTint="@color/card_background"
        android:elevation="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Control Center"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp"
            android:letterSpacing="0.05"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="500dp"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="4dp">

                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/rounded_background"
                        android:backgroundTint="#1AFFFFFF"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_brightness_stat"
                            android:tint="@color/nord8"/>
                        <SeekBar
                            android:id="@+id/brightness_seekbar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="255"
                            android:progressTint="@color/nord8"
                            android:thumbTint="@color/nord8"
                            android:splitTrack="false"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>
                    </LinearLayout>

                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/rounded_background"
                        android:backgroundTint="#1AFFFFFF"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:id="@+id/img_volume_media_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_volume_up_stat"
                            android:tint="@color/nord9"/>
                        <SeekBar
                            android:id="@+id/volume_media_seekbar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:progressTint="@color/nord9"
                            android:thumbTint="@color/nord9"
                            android:splitTrack="false"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>
                    </LinearLayout>

                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/rounded_background"
                        android:backgroundTint="#1AFFFFFF"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:id="@+id/img_volume_ring_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_vibrate_stat"
                            android:tint="@color/nord13"/>
                        <SeekBar
                            android:id="@+id/volume_ring_seekbar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:progressTint="@color/nord13"
                            android:thumbTint="@color/nord13"
                            android:splitTrack="false"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>
                    </LinearLayout>

                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/rounded_background"
                        android:backgroundTint="#1AFFFFFF"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:id="@+id/img_volume_alarm_icon"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_lock_silent_mode"
                                android:tint="@color/nord11"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ALARM"
                                android:textColor="@color/nord11"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <SeekBar
                            android:id="@+id/volume_alarm_seekbar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:progressTint="@color/nord11"
                            android:thumbTint="@color/nord11"
                            android:splitTrack="false"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"/>
                    </LinearLayout>
                </LinearLayout>

                
                <GridLayout
                    android:id="@+id/shortcuts_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:alignmentMode="alignMargins">
                    
                </GridLayout>
            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</FrameLayout>
