<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    
    <ImageView
        android:id="@+id/wallpaper_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Background"
        android:scaleType="centerCrop" />

    
    <View
        android:id="@+id/settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="20dp">

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Widgets"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/white"
                    android:letterSpacing="-0.01"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Enable, disable, and reorder your widgets"
                    android:textColor="@color/white"
                    android:alpha="0.5"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/widget_config_search_background"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search"
                android:scaleType="fitCenter"
                app:tint="@color/white"
                android:alpha="0.5" />

            <EditText
                android:id="@+id/search_widget_input"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search widgets"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="0dp"
                android:textColor="@color/white"
                android:textColorHint="@color/white"
                android:textCursorDrawable="@null"
                android:textSize="15sp"
                android:alpha="0.9" />

        </LinearLayout>

        
        <TextView
            android:id="@+id/widgets_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 widgets"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/nord8"
            android:letterSpacing="0.05"
            android:layout_marginBottom="12dp"
            android:paddingStart="4dp"/>

        
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/widgets_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/empty_state_text"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="24dp"
            android:text="No widgets match your search."
            android:textAlignment="center"
            android:textColor="@color/widget_config_text_secondary"
            android:textSize="15sp"
            android:alpha="0.6"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
