<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Wallpaper Background -->
    <ImageView
        android:id="@+id/wallpaper_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Background"
        android:scaleType="centerCrop" />

    <!-- Semi-transparent overlay for better text visibility -->
    <View
        android:id="@+id/settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <!-- Title & Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="32dp"
            android:paddingHorizontal="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Widgets"
                    android:textSize="38sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/white"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="6"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Drawer layout"
                    android:textColor="@color/white"
                    android:alpha="0.6"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/save_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#33FFFFFF"
                app:strokeWidth="1dp"
                app:strokeColor="#20FFFFFF"
                android:clickable="true"
                android:focusable="true">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAVE"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Search Bar Section (No outer card) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/settings_card_background"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_search"
                android:contentDescription="Search"
                android:padding="12dp"
                android:scaleType="fitCenter"
                app:tint="@color/white"
                android:alpha="0.6" />

            <EditText
                android:id="@+id/search_widget_input"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search widgets"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="4dp"
                android:paddingEnd="14dp"
                android:textColor="@color/white"
                android:textColorHint="#66FFFFFF"
                android:textCursorDrawable="@null"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- Category Label -->
        <TextView
            android:id="@+id/widgets_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENABLED WIDGETS"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/nord8"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="12dp"/>

        <!-- Instruction Text (Moved below enabled widgets text) -->
        <TextView
            android:id="@+id/instruction_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="12dp"
            android:text="Drag handles to reorder. Tap a card to toggle."
            android:textColor="@color/white"
            android:alpha="0.5"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp" />

        <!-- Widgets List Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="32dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="24dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/outlineColor">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/widgets_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:padding="8dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</FrameLayout>
