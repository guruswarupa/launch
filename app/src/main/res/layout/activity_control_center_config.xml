<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/wallpaper_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/background"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- Tab Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/tab_customize"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Customize"
                    android:textAllCaps="false"
                    android:background="@drawable/settings_card_background"
                    android:textColor="@color/white"/>

                <Button
                    android:id="@+id/tab_handle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Handle"
                    android:textAllCaps="false"
                    android:background="@drawable/settings_card_background"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Shortcuts Content -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/shortcuts_card"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outlineColor">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/subtitle_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Drag handles to reorder shortcuts. Toggle visibility to customize your control center panel."
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:alpha="0.5"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:lineSpacingExtra="2dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_shortcuts"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trigger Settings Content (initially hidden) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/trigger_card"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/outlineColor">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Customize the trigger line that appears at the corner of the screen"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:alpha="0.5"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:lineSpacingExtra="2dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="@string/control_center_trigger_position"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <Spinner
                            android:id="@+id/trigger_position_spinner"
                            style="@style/TranslucentSpinnerStyle"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/control_center_trigger_lock"
                                android:textColor="@color/white"
                                android:textSize="14sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/trigger_lock_switch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:thumbTint="@color/nord8"
                                app:trackTint="#30FFFFFF" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:text="@string/control_center_trigger_transparency"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <SeekBar
                            android:id="@+id/trigger_alpha_seekbar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:max="80"
                            android:progressTint="@color/nord8"
                            android:thumbTint="@color/nord8" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:text="@string/control_center_trigger_size"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <SeekBar
                            android:id="@+id/trigger_height_seekbar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:max="72"
                            android:progressTint="@color/nord8"
                            android:thumbTint="@color/nord8" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="22dp"
                            android:text="@string/control_center_trigger_width"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <SeekBar
                            android:id="@+id/trigger_width_seekbar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:max="24"
                            android:progressTint="@color/nord8"
                            android:thumbTint="@color/nord8" />
                    </LinearLayout>
                </ScrollView>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:padding="16dp"
                    android:text="@string/cancel_button"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/btn_save"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:padding="16dp"
                    android:text="@string/save_button"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
