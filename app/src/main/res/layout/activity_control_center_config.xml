<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Wallpaper Background -->
    <ImageView
        android:id="@+id/wallpaper_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="Background"/>

    <!-- Semi-transparent overlay -->
    <View
        android:id="@+id/settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/settings_overlay"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customize Control Center"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Drag items to reorder them and toggle visibility with the switches."
            android:textSize="14sp"
            android:textColor="@color/text"
            android:alpha="0.8"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/shortcut_list_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"
            android:background="@drawable/widget_background"
            android:padding="16dp"
            android:clipToPadding="false"
            android:clipChildren="false">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_shortcuts"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:background="@drawable/button_neutral_ripple"
            android:textColor="@color/text"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>

</FrameLayout>
