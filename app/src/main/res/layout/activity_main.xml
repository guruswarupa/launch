<com.guruswarupa.launch.ui.views.SafeDrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    
    <FrameLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        
        <ImageView
            android:id="@+id/wallpaper_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:layout_gravity="center"/>

        
        <View
            android:id="@+id/background_translucency_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#00000000"/>

        
        <androidx.core.widget.NestedScrollView
            android:id="@+id/main_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        
        <LinearLayout
            android:id="@+id/main_content_stack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="@dimen/main_content_stack_top_padding"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="@dimen/main_content_stack_bottom_padding"
            android:gravity="top"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:animateLayoutChanges="true"
            android:descendantFocusability="beforeDescendants">

            
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:focusable="true"
                android:focusableInTouchMode="true">
                <requestFocus />
            </View>

            
            <LinearLayout
                android:id="@+id/top_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="@dimen/widget_status_bar_clearance"
                android:layout_marginBottom="16dp"
                android:background="@drawable/widget_background">

                
                <TextView
                    android:id="@+id/time_widget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="32sp"
                    android:textColor="@color/widget_text"
                    android:gravity="center"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.05"
                    android:paddingTop="8dp" />

                
                <TextView
                    android:id="@+id/date_widget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textColor="@color/widget_text"
                    android:gravity="center"
                    android:fontFamily="sans-serif-light"
                    android:paddingTop="8dp" />

                
                <LinearLayout
                    android:id="@+id/weather_widget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="8dp">

                    <ImageView
                        android:id="@+id/weather_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Weather Icon"/>

                    <TextView
                        android:id="@+id/weather_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textColor="@color/widget_text"
                        android:fontFamily="sans-serif-light"/>
                </LinearLayout>

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:gravity="center">

                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/battery_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Battery: 100%"
                            android:textSize="14sp"
                            android:textColor="@color/widget_text"
                            android:fontFamily="sans-serif-light"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/search_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/search_container_bottom_margin"
                android:background="@drawable/search_box_transparent_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/search_type_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Search Type"
                    android:padding="12dp"
                    android:scaleType="fitCenter" />

                <AutoCompleteTextView
                    android:id="@+id/search_box"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/search_text"
                    android:textColor="@color/widget_text"
                    android:textColorHint="@color/widget_text_secondary"
                    android:padding="12dp"
                    android:background="@null"
                    android:textSize="16sp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:dropDownSelector="?android:attr/listChoiceBackgroundIndicator"
                    android:popupBackground="@drawable/spinner_dropdown_background"
                    android:dropDownWidth="wrap_content"
                    android:dropDownHeight="wrap_content"
                    android:dropDownVerticalOffset="0dp"
                    android:dropDownHorizontalOffset="0dp"/>

                <ImageButton
                    android:id="@+id/voice_search_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="Voice Search" />
            </LinearLayout>

            
            <com.guruswarupa.launch.ui.views.SafeHorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:padding="8dp"
                android:layout_marginBottom="20px">

                <LinearLayout
                    android:id="@+id/app_dock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingEnd="16dp"/>
            </com.guruswarupa.launch.ui.views.SafeHorizontalScrollView>
            
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/app_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:clipToPadding="false"
                android:clipChildren="false" />

            <TextView
                android:id="@+id/app_list_empty_state"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/app_list_no_apps_found"
                android:textSize="16sp"
                android:visibility="gone" />
        </LinearLayout>

        
        
        <com.guruswarupa.launch.ui.views.FastScroller
            android:id="@+id/fast_scroller"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="@android:color/transparent"
            android:visibility="gone"
            android:elevation="32dp"
            android:translationZ="32dp"
            android:clickable="true"
            android:focusable="false"
            android:outlineProvider="none" />

    </FrameLayout>

    
    <include layout="@layout/page_rss_feed" />

    
    <FrameLayout
        android:id="@+id/widgets_drawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true">

        
        <ImageView
            android:id="@+id/drawer_wallpaper_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:layout_gravity="center"/>

        
        <View
            android:id="@+id/widgets_drawer_translucency_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#00000000"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/drawer_widgets_overlay" />

        
        <LinearLayout
            android:id="@+id/widget_settings_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/drawer_widgets_header_bg"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_settings_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Widgets"
                    android:textColor="@color/widget_text"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Your personalized drawer"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/widget_config_button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/drawer_widgets_action_bg"
                android:src="@drawable/ic_settings_icon"
                android:tint="@color/widget_text"
                android:contentDescription="Configure Widgets" />
        </LinearLayout>

        
        <androidx.core.widget.NestedScrollView
            android:id="@+id/widgets_drawer_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:paddingTop="94dp">

            <LinearLayout
                android:id="@+id/drawer_content_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="0dp"
                android:paddingTop="14dp"
                android:paddingEnd="0dp"
                android:paddingBottom="16dp"
                android:animateLayoutChanges="true">

            
            <LinearLayout
                android:id="@+id/widgets_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/drawer_widgets_empty_state_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingTop="28dp"
                android:paddingEnd="24dp"
                android:paddingBottom="28dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/drawer_widgets_empty_icon_bg"
                    android:foregroundGravity="center">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_widget_placeholder"
                        android:tint="@color/widget_text" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No widgets enabled"
                    android:textColor="@color/widget_text"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap Gear icon above to add and configure widgets"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:alpha="0.78" />
            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/media_controller_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginVertical="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/notifications_widget_main_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <FrameLayout
                    android:id="@+id/notifications_widget_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/calendar_events_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/countdown_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/dns_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/note_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/physical_activity_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/compass_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/pressure_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/temperature_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <LinearLayout
                android:id="@+id/weather_forecast_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/network_stats_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/device_info_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/year_progress_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/github_contributions_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/battery_health_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/weekly_usage_widget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Weekly Usage"
                    android:textSize="18sp"
                    android:textColor="@color/widget_text"
                    android:textStyle="bold"
                    android:gravity="start"
                    android:layout_marginBottom="16dp"/>

                <com.guruswarupa.launch.ui.views.WeeklyUsageGraphView
                    android:id="@+id/weekly_usage_graph"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/request_usage_stats_permission_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grant Usage Access Permission"
                    android:textColor="@color/widget_text"
                    android:textSize="14sp"
                    android:background="@drawable/button_neutral_ripple"
                    android:paddingVertical="12dp"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />
            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/noise_decibel_widget_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            
            <LinearLayout
                android:id="@+id/workout_widget_main_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <FrameLayout
                    android:id="@+id/workout_widget_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/calculator_widget_main_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Calculator"
                        android:textColor="@color/widget_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/calculator_widget_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/todo_widget_main_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/widget_background"
                android:padding="20dp"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Todo List"
                        android:textColor="@color/widget_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/add_todo_button"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/button_neutral_ripple"
                        android:src="@drawable/ic_add"
                        android:contentDescription="Add todo item"
                        android:padding="8dp" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/todo_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="300dp"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/finance_widget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/widget_background"
                android:orientation="vertical"
                android:padding="20dp">

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Finance Tracker"
                        android:textColor="@color/widget_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/finance_currency_spinner"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/button_neutral_ripple"
                        android:paddingHorizontal="8dp" />
                </LinearLayout>

                
                <LinearLayout
                    android:id="@+id/balance_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/balance_card_ripple"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Balance"
                        android:textColor="@color/widget_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/balance_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textColor="@color/widget_text"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/monthly_spent_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="This Month: -$0.00"
                            android:textColor="@color/widget_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/amount_input"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/input_field_background"
                        android:hint="Enter amount"
                        android:inputType="numberDecimal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:textColor="@color/widget_text"
                        android:textColorHint="@color/widget_text_secondary"
                        android:textSize="16sp"
                        android:layout_marginBottom="12dp" />

                    <EditText
                        android:id="@+id/description_input"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/input_field_background"
                        android:hint="Description (optional)"
                        android:inputType="text"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:textColor="@color/widget_text"
                        android:textColorHint="@color/widget_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/add_income_btn"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/button_neutral_ripple"
                        android:text="Add Income"
                        android:textColor="@color/widget_text"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:elevation="4dp" />

                    <Button
                        android:id="@+id/add_expense_btn"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/button_neutral_ripple"
                        android:text="Add Expense"
                        android:textColor="@color/widget_text"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:elevation="4dp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

    
    <FrameLayout
        android:id="@+id/wallpaper_drawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:clickable="true"
        android:focusable="true">

        
        <ImageView
            android:id="@+id/right_drawer_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:layout_gravity="center"/>

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="64dp"
            android:padding="24dp">

            <TextView
                android:id="@+id/right_drawer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="80sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="0.1"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:text="00:00"/>

            <TextView
                android:id="@+id/right_drawer_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.2"
                android:textAllCaps="true"
                android:layout_marginTop="-8dp"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:text="MONDAY, 01 JAN"/>
        </LinearLayout>
    </FrameLayout>

</com.guruswarupa.launch.ui.views.SafeDrawerLayout>
