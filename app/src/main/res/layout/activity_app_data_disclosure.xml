<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    
    <ImageView
        android:id="@+id/disclosure_wallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@android:color/black" />

    
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    
    <LinearLayout
        android:id="@+id/welcome_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/welcome_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-thin"
            android:text="Welcome"
            android:textColor="@color/white"
            android:textSize="64sp"
            android:alpha="0"
            android:scaleX="0.8"
            android:scaleY="0.8" />

        <TextView
            android:id="@+id/welcome_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.2"
            android:text="TO LAUNCH"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:alpha="0"
            android:textAllCaps="true" />
    </LinearLayout>

    
    <LinearLayout
        android:id="@+id/disclosure_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="16dp"
                    android:src="@mipmap/ic_launcher_round"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:id="@+id/disclosure_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_data_disclosure_title"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-light"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:letterSpacing="0.02"
                    android:layout_marginBottom="24dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/widget_background"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/disclosure_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/app_data_disclosure_message"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-light"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="48dp"
                    android:background="@color/white"
                    android:alpha="0.1"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESOURCES"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/nord8"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp"
                    android:alpha="0.8" />

                <TextView
                    android:id="@+id/disclosure_links"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/data_disclosure_links"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:alpha="0.8"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginBottom="32dp"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/decline_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/decline"
                android:background="@drawable/button_black_translucent_ripple"
                app:backgroundTint="@null"
                android:textColor="@color/white"
                android:textAllCaps="true"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:paddingHorizontal="16dp" />

            <Button
                android:id="@+id/accept_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/i_agree"
                android:background="@drawable/button_black_translucent_ripple"
                app:backgroundTint="@null"
                android:textColor="@color/white"
                android:textAllCaps="true"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:paddingHorizontal="16dp" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/feature_onboarding_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/feature_onboarding_step_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DISCOVER LAUNCH"
                android:textColor="@color/nord8"
                android:textSize="12sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.18" />

            <Button
                android:id="@+id/feature_onboarding_skip_button"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:minWidth="0dp"
                android:text="Skip"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.2" />

        <LinearLayout
            android:id="@+id/feature_onboarding_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <LinearLayout
                android:id="@+id/feature_visual_card"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/widget_background"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/feature_icon_chip_start"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/circular_background"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/feature_icon_start"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@null"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/feature_icon_chip_center"
                        android:layout_width="84dp"
                        android:layout_height="84dp"
                        android:background="@drawable/circular_background"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/feature_icon_center"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:contentDescription="@null"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/feature_icon_chip_end"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/circular_background"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/feature_icon_end"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@null"
                            app:tint="@color/white" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/feature_visual_caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:text="Search. Focus. Make the launcher work for you."
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-light"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/feature_onboarding_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:text="Everything important is right on the home screen"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:fontFamily="sans-serif-thin"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:id="@+id/feature_onboarding_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Launch helps you search faster, manage apps better, and open actions without digging through settings."
                android:textColor="@color/white"
                android:textSize="16sp"
                android:alpha="0.9"
                android:fontFamily="sans-serif-light"
                android:lineSpacingExtra="5dp" />

            <TextView
                android:id="@+id/feature_onboarding_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="You can still customize everything later."
                android:textColor="@color/nord8"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/feature_page_indicators"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/feature_onboarding_back_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Back"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@drawable/button_black_translucent_ripple"
                app:backgroundTint="@null"
                android:fontFamily="sans-serif-medium" />

            <Button
                android:id="@+id/feature_onboarding_next_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Continue"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@drawable/button_black_translucent_ripple"
                app:backgroundTint="@null"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    
    <LinearLayout
        android:id="@+id/import_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_archive"
            app:tint="@color/nord8" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import Old Data"
            android:textSize="28sp"
            android:fontFamily="sans-serif-light"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Do you want to restore your previous configuration? You can import your layout, hidden apps, and settings from a backup file."
            android:textSize="16sp"
            android:textColor="@color/white"
            android:alpha="0.8"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/import_data_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Choose Backup File"
            android:background="@drawable/button_black_translucent_ripple"
            app:backgroundTint="@null"
            android:textColor="@color/white"
            android:textAllCaps="true"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/skip_import_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Fresh"
            android:background="@android:color/transparent"
            android:textColor="@color/white"
            android:alpha="0.6"
            android:textAllCaps="true"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black" />

    </LinearLayout>
</FrameLayout>
