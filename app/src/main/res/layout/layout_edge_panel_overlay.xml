<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/edge_panel_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01000000">

    <View
        android:id="@+id/edge_panel_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000"
        android:clickable="true"
        android:focusable="true"
        android:alpha="0" />

    <LinearLayout
        android:id="@+id/edge_panel_sheet"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_edge_panel_sheet"
        android:elevation="16dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="invisible"
        android:alpha="0">

        <ScrollView
            android:id="@+id/edge_panel_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="10dp">

                <TextView
                    android:id="@+id/edge_panel_recent_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:text="Recent"
                    android:textAllCaps="true"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:id="@+id/edge_panel_recent_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/edge_panel_pinned_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:text="Pinned"
                    android:textAllCaps="true"
                    android:textColor="#B3FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:id="@+id/edge_panel_pinned_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/edge_panel_recent_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="No apps"
                    android:textColor="#B3FFFFFF"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/edge_panel_usage_permission_button"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edge_panel_icon_slot"
                    android:padding="14dp"
                    android:src="@drawable/ic_apps_grid"
                    android:tint="@color/white"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="#26FFFFFF" />

        <ImageView
            android:id="@+id/edge_panel_customize_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_edge_panel_icon_slot"
            android:padding="14dp"
            android:src="@drawable/ic_settings_icon"
            android:tint="@color/white" />
    </LinearLayout>
</FrameLayout>
