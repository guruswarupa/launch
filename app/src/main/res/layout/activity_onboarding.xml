<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/wallpaper_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Background"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/onboarding_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/onboarding_backdrop_scrim" />

    <ScrollView
        android:id="@+id/onboarding_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-medium"
                android:text="LAUNCH SETUP"
                android:textColor="@color/white"
                android:letterSpacing="0.1"
                android:alpha="0.8"
                android:textSize="11sp" />

            <LinearLayout
                android:id="@+id/hero_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/onboarding_hero_card"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:id="@+id/progress_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Step 1 of 7"
                    android:textColor="@color/onboarding_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/progress_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Shape Launch around the way you want to use your home screen."
                    android:textColor="@color/onboarding_text"
                    android:textSize="22sp" />

                <LinearLayout
                    android:id="@+id/progress_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/step1_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circular_indicator" />

                    <View
                        android:id="@+id/step1_connector"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginHorizontal="6dp"
                        android:layout_weight="1"
                        android:background="@color/onboarding_step_indicator_inactive" />

                    <View
                        android:id="@+id/step2_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circular_indicator" />

                    <View
                        android:id="@+id/step2_connector"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginHorizontal="6dp"
                        android:layout_weight="1"
                        android:background="@color/onboarding_step_indicator_inactive" />

                    <View
                        android:id="@+id/step3_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circular_indicator" />

                    <View
                        android:id="@+id/step3_connector"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginHorizontal="6dp"
                        android:layout_weight="1"
                        android:background="@color/onboarding_step_indicator_inactive" />

                    <View
                        android:id="@+id/step4_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circular_indicator" />

                    <View
                        android:id="@+id/step4_connector"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginHorizontal="6dp"
                        android:layout_weight="1"
                        android:background="@color/onboarding_step_indicator_inactive" />

                    <View
                        android:id="@+id/step5_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circular_indicator" />

                    <View
                        android:id="@+id/step5_connector"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginHorizontal="6dp"
                        android:layout_weight="1"
                        android:background="@color/onboarding_step_indicator_inactive" />

                    <View
                        android:id="@+id/step6_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circular_indicator" />

                    <View
                        android:id="@+id/step6_connector"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginHorizontal="6dp"
                        android:layout_weight="1"
                        android:background="@color/onboarding_step_indicator_inactive" />

                    <View
                        android:id="@+id/step7_indicator"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circular_indicator" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/step_content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/onboarding_surface_card"
                android:minHeight="400dp"
                android:padding="28dp">

                <LinearLayout
                    android:id="@+id/welcome_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="Welcome to Launch"
                        android:textColor="@color/onboarding_text"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="A launcher built for quick access, focused screens, and a calmer home layout."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="28dp"
                        android:background="@color/onboarding_divider" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="What this setup covers"
                        android:textColor="@color/onboarding_text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Privacy and permissions"
                        android:textColor="@color/onboarding_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Default launcher, layout style, favorites, and workspace structure"
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Optional weather integration and backup restore"
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/data_privacy_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Data privacy"
                        android:textColor="@color/onboarding_text"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Launch needs local access to your installed apps so it can actually behave like a launcher."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/onboarding_divider" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Installed apps disclosure"
                        android:textColor="@color/onboarding_text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Launch reads your installed application list to render the home screen, power search, and organize apps into workspaces."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Commitment"
                        android:textColor="@color/onboarding_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="• Processed locally on your device\n• Not uploaded to external servers\n• Not shared with third parties"
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="Selecting I Agree confirms this local access."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/permissions_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Permissions"
                        android:textColor="@color/onboarding_text"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Each request is explained before Android shows it. Anything skipped here can still be granted later."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/onboarding_divider" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Included in this step"
                        android:textColor="@color/onboarding_text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Contacts, calls, messages, notifications, media access, usage stats, and advanced launcher services."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/default_launcher_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Set Launch as default"
                        android:textColor="@color/onboarding_text"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:text="This replaces your current home app so Launch can own the home gesture and launcher shortcuts."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/onboarding_divider" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Recommended"
                        android:textColor="@color/onboarding_step_indicator_active"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Set it now to test widgets, gestures, search, and workspace switching in the real launcher context."
                        android:textColor="@color/onboarding_text"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/backup_import_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Restore an existing setup"
                        android:textColor="@color/onboarding_text"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Import a backup if you already configured Launch before. Otherwise continue and build a fresh layout."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <Button
                        android:id="@+id/import_backup_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/onboarding_primary_button"
                        android:fontFamily="sans-serif-medium"
                        android:minHeight="56dp"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="16dp"
                        android:text="Import Backup"
                        android:textAllCaps="false"
                        android:textColor="@color/onboarding_primary_button_text"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/display_style_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Choose your display style"
                        android:textColor="@color/onboarding_text"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Pick the default app drawer presentation. You can change it later."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/grid_style_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/onboarding_option_button"
                            android:fontFamily="sans-serif-medium"
                            android:minHeight="0dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:text="Grid"
                            android:textAllCaps="false"
                            android:textColor="@color/onboarding_text"
                            android:textSize="18sp" />

                        <Button
                            android:id="@+id/list_style_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/onboarding_option_button"
                            android:fontFamily="sans-serif-medium"
                            android:minHeight="0dp"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:text="List"
                            android:textAllCaps="false"
                            android:textColor="@color/onboarding_text"
                            android:textSize="18sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/favorites_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Choose favorites"
                        android:textColor="@color/onboarding_text"
                        android:textSize="26sp" />

                    <TextView
                        android:id="@+id/favorites_loading_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:gravity="center"
                        android:text="Loading apps..."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="These apps will be pinned into your default launcher experience first."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <com.guruswarupa.launch.ui.views.WrapContentRecyclerView
                        android:id="@+id/favorites_recycler_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@android:color/transparent"
                        android:clipToPadding="false"
                        android:fadeScrollbars="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingBottom="12dp"
                        android:scrollbars="none" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/workspaces_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Create workspaces"
                        android:textColor="@color/onboarding_text"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Split apps into focused spaces like Work, Personal, Study, or Travel."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/workspace_name_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/onboarding_input_field"
                        android:hint="Workspace name"
                        android:minHeight="56dp"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="16dp"
                        android:textColor="@color/onboarding_input_text"
                        android:textColorHint="@color/onboarding_input_hint"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/workspaces_list_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Saved workspaces"
                        android:textColor="@color/onboarding_text"
                        android:textSize="16sp"
                        android:visibility="gone" />

                    <com.guruswarupa.launch.ui.views.WrapContentRecyclerView
                        android:id="@+id/workspaces_list_recycler_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/transparent"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingBottom="6dp"
                        android:scrollbars="none"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/workspaces_loading_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="Loading apps..."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Select apps for the workspace"
                        android:textColor="@color/onboarding_text"
                        android:textSize="15sp" />

                    <com.guruswarupa.launch.ui.views.WrapContentRecyclerView
                        android:id="@+id/workspaces_apps_recycler_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@android:color/transparent"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingBottom="12dp"
                        android:scrollbars="none" />

                    <Button
                        android:id="@+id/add_workspace_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/onboarding_primary_button"
                        android:fontFamily="sans-serif-medium"
                        android:minHeight="56dp"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="16dp"
                        android:text="Create Workspace"
                        android:textAllCaps="false"
                        android:textColor="@color/onboarding_primary_button_text"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/weather_api_key_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Weather setup"
                        android:textColor="@color/onboarding_text"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Add an OpenWeatherMap API key if you want live weather on the launcher. This step is optional."
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="15sp" />

                    <EditText
                        android:id="@+id/weather_api_key_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/onboarding_input_field"
                        android:hint="OpenWeatherMap API key"
                        android:inputType="text"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="16dp"
                        android:singleLine="true"
                        android:textColor="@color/onboarding_input_text"
                        android:textColorHint="@color/onboarding_input_hint"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Get a free key at openweathermap.org/api"
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/weather_location_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/onboarding_input_field"
                        android:hint="City name"
                        android:inputType="text"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="16dp"
                        android:singleLine="true"
                        android:textColor="@color/onboarding_input_text"
                        android:textColorHint="@color/onboarding_input_hint"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Example: Bengaluru, London, or New York"
                        android:textColor="@color/onboarding_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/complete_step"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="All set"
                        android:textColor="@color/onboarding_text"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="Your launcher setup is ready. Open Launch and start refining it from the home screen."
                        android:textColor="@color/white"
                        android:textSize="15sp" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/navigation_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/back_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/onboarding_secondary_button"
                    android:fontFamily="sans-serif-medium"
                    android:minHeight="52dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:text="Back"
                    android:textAllCaps="false"
                    android:textColor="@color/onboarding_secondary_button_text"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/next_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/onboarding_primary_button"
                    android:fontFamily="sans-serif-medium"
                    android:minHeight="52dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:text="Next"
                    android:textAllCaps="false"
                    android:textColor="@color/onboarding_primary_button_text"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:alpha="0.65"
                android:text="Developed by Guru Swarupa"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>

</FrameLayout>
