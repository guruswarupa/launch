<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rss_feed_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/rss_wallpaper_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/rss_drawer_translucency_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/drawer_widgets_overlay" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/rss_swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:enabled="true"
        android:paddingTop="174dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rss_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="24dp"
                android:scrollbars="none" />

            <LinearLayout
                android:id="@+id/rss_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/drawer_widgets_empty_state_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="24dp"
                android:paddingTop="28dp"
                android:paddingEnd="24dp"
                android:paddingBottom="28dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/drawer_widgets_empty_icon_bg"
                    android:foregroundGravity="center">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_browser"
                        android:tint="@color/widget_text" />
                </FrameLayout>

                <TextView
                    android:id="@+id/rss_empty_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No news sources enabled"
                    android:textColor="@color/widget_text"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/rss_empty_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open feed settings and switch on the sources you want to read here."
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:alpha="0.78" />

            </LinearLayout>
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <LinearLayout
        android:id="@+id/rss_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/drawer_widgets_header_bg"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/rss_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="News Feed"
                android:textColor="@color/widget_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Your headlines in one place"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/rss_refresh_button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/drawer_widgets_action_bg"
                android:contentDescription="Refresh RSS feeds"
                android:src="@drawable/ic_refresh"
                android:tint="@color/widget_text" />

            <ImageButton
                android:id="@+id/rss_manage_button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/drawer_widgets_action_bg"
                android:contentDescription="Manage RSS feeds"
                android:src="@drawable/ic_settings_icon"
                android:tint="@color/widget_text" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/rss_topic_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="126dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="2dp"
        app:singleSelection="true"
        app:selectionRequired="true" />

</FrameLayout>
